# Fashion Recommendation System - Environment Configuration Template
# Copy this file to .env and fill in your values

# Backend Configuration
PROJECT_NAME="Fashion Recommendation"
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Database
DATABASE_URL=sqlite:///./fashion.db

# CORS - Frontend URLs (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ML Model Configuration
MODEL_NAME=Qwen/Qwen2-VL-7B-Instruct
MODEL_CACHE_DIR=~/.cache/huggingface/hub
DEVICE=auto  # auto, cuda, cpu

# Weather API (when implementing real API)
# WEATHER_API_KEY=your_openweathermap_api_key
# WEATHER_API_URL=https://api.openweathermap.org/data/2.5/weather

# Security (for future JWT implementation)
# SECRET_KEY=your-secret-key-here
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
