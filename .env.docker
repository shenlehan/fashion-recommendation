# Docker Environment Configuration
# This file is used when running with Docker Compose
# Copy this to .env and customize as needed

# ============================================
# Backend Configuration
# ============================================

# Database
DATABASE_URL=sqlite:///./fashion.db

# CORS Origins (comma-separated)
# Add your frontend URLs here
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80,http://localhost

# ============================================
# ML Model Configuration
# ============================================

# Model name from HuggingFace
MODEL_NAME=Qwen/Qwen2-VL-7B-Instruct

# Device: auto (detect), cuda (GPU), or cpu
DEVICE=auto

# Model cache directory (inside container)
MODEL_CACHE_DIR=/root/.cache/huggingface/hub

# ============================================
# File Upload Configuration
# ============================================

# Upload directory
UPLOAD_DIR=uploads

# Max upload size in MB
MAX_UPLOAD_SIZE_MB=10

# ============================================
# Frontend Configuration
# ============================================

# API URL (for frontend to connect to backend)
VITE_API_URL=http://localhost:8000

# ============================================
# Optional: GPU Configuration
# ============================================

# Uncomment the following in docker-compose.yml to enable GPU:
# deploy:
#   resources:
#     reservations:
#       devices:
#         - driver: nvidia
#           count: 1
#           capabilities: [gpu]

# ============================================
# Optional: Security (Future Implementation)
# ============================================

# SECRET_KEY=your-secret-key-here-change-in-production
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
